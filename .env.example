# Database — local dev: Supabase local (supabase start). Remote/staging: use pooler URLs from Supabase Dashboard.
# Local (default): postgres runs on port 54322.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
DATABASE_URL_READER=postgresql://postgres:postgres@127.0.0.1:54322/postgres
DATABASE_URL_WRITER=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# Remote example (pooler port 6543): postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Encryption
CPF_ENCRYPTION_KEY=<32-byte-hex-encoded-aes256-key>

# External APIs
TRANSPARENCIA_API_KEY=<portal-da-transparencia-api-key>
VERCEL_REVALIDATE_TOKEN=<secure-random-token>

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
# Frontend public base URL (used for canonical URLs, OG metadata, sitemap)
NEXT_PUBLIC_BASE_URL=https://autoridade-politica.com.br

# Pipeline Scheduler (cron expressions in São Paulo timezone)
CRON_SCHEDULE_CAMARA=0 2 * * *
CRON_SCHEDULE_SENADO=0 3 * * *
CRON_SCHEDULE_TRANSPARENCIA=0 4 * * *
CRON_SCHEDULE_TSE=0 5 * * 0
CRON_SCHEDULE_TCU=0 6 * * *
CRON_SCHEDULE_CGU=0 7 * * *

# App
NODE_ENV=development
LOG_LEVEL=info
PORT=3001
HOST=0.0.0.0
